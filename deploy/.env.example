# EGX Investment API - Production Environment Configuration
# Copy this file to .env on your Hostinger server and update values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=EGX Investment API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
NODE_ENV=production

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# SQLite (Recommended for Hostinger - easiest setup)
DATABASE_URL=sqlite://./egx_investment.db

# MySQL (If you want to use Hostinger's MySQL - uncomment and fill in details)
# DATABASE_URL=mysql://your_db_user:your_db_password@localhost:3306/your_db_name

# ===========================================
# SECURITY SETTINGS - CHANGE THESE!
# ===========================================
# Generate a strong API key (32+ characters)
API_KEYS=CHANGE_THIS_TO_YOUR_PRODUCTION_API_KEY

# Generate a strong secret key (32+ characters minimum)
# You can use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=CHANGE_THIS_TO_YOUR_SUPER_SECRET_KEY_MIN_32_CHARS

# Token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===========================================
# CORS SETTINGS
# ===========================================
# Replace with your actual domain(s)
CORS_ORIGINS=https://invist.m2y.net,https://www.invist.m2y.net
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-API-Key

# ===========================================
# SCHEDULER SETTINGS
# ===========================================
SCHEDULER_ENABLED=true
DATA_UPDATE_INTERVAL_MINUTES=15

# Trading hours (Cairo time)
TRADING_START_HOUR=8
TRADING_END_HOUR=16
TRADING_DAYS=0,1,2

# ===========================================
# EXTERNAL API KEYS
# ===========================================
# Twelve Data API (https://twelvedata.com)
TWELVE_DATA_API_KEY=YOUR_TWELVEDATA_API_KEY

# EODHD API (https://eodhd.com)
EODHD_API_KEY=YOUR_EODHD_API_KEY

# Together.ai API for AI-powered features
TOGETHER_API_KEY=YOUR_TOGETHER_API_KEY
TOGETHER_MODEL=Qwen3-Next-80B-A3B-Instruct

# ===========================================
# USER AUTHENTICATION
# ===========================================
USER_API_KEY=YOUR_SECURE_USER_API_KEY

# Google OAuth (Optional - if using Google login)
GOOGLE_CLIENT_ID=642150971767-t1nlndjb5a5qp2a6gcq0irih8q75b16t.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://invist.m2y.net/api/auth/google/callback

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ===========================================
# SERVER PORT
# ===========================================
# Hostinger will typically set this automatically
# Check your Node.js app settings in hPanel
PORT=8100
