# EGX Investment API Environment Configuration
# Copy this file to .env and update values for your environment

# Application
APP_NAME=EGX Investment API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Database - using psycopg driver (works on Windows without PostgreSQL installed)
DATABASE_URL=postgresql+psycopg://egx_user:egx_secure_password@localhost:5432/egx_investment
DATABASE_URL_SYNC=postgresql+psycopg://egx_user:egx_secure_password@localhost:5432/egx_investment

# Security - CHANGE THESE IN PRODUCTION!
API_KEYS=egx_your_api_key_here,another_api_key_if_needed
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# CORS
CORS_ORIGINS=*

# Scheduler
SCHEDULER_ENABLED=true
DATA_UPDATE_INTERVAL_MINUTES=15

# External API Keys
# Twelve Data API (https://twelvedata.com)
TWELVE_DATA_API_KEY=821e4b4a88874941af581ad4d3141d93

# EODHD API (https://eodhd.com)
EODHD_API_KEY=6990ef9ee966c5.41761316

# Together.ai API for AI-powered features
TOGETHER_API_KEY=key_CUJoQk5chstN2WCQmjzJT
TOGETHER_MODEL=Qwen3-Next-80B-A3B-Instruct

# User API Key
USER_API_KEY=2a04bb8e3a549176ed4b52f0ea632fc463de859581d8e2adbc1298cc1783548e

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log