{
    "name": "investment-fullstack",
    "version": "1.0.0",
    "description": "EGX Investment Platform - Node.js Backend",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "build:css": "npx tailwindcss@3.4.17 -i ./frontend/css/input.css -o ./frontend/css/tailwind.css --minify",
        "watch:css": "npx tailwindcss@3.4.17 -i ./frontend/css/input.css -o ./frontend/css/tailwind.css --watch",
        "init:db": "node scripts/init_db.js"
    },
    "dependencies": {
        "axios": "^1.6.5",
        "bcryptjs": "^2.4.3",
        "cheerio": "^1.0.0-rc.12",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.5",
        "google-auth-library": "^10.6.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "node-cron": "^3.0.3",
        "pg": "^8.11.3",
        "playwright": "^1.40.1",
        "sequelize": "^6.35.2",
        "sqlite3": "^5.1.6",
        "winston": "^3.11.0",
        "yargs": "^17.7.2"
    },
    "devDependencies": {
        "nodemon": "^3.0.2"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
